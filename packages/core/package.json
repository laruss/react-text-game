{
    "name": "@react-text-game/core",
    "version": "0.6.0",
    "description": "A powerful React-based text game engine with reactive state management, passage-based navigation, and persistent save system for building interactive narrative experiences",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": "github:laruss/react-text-game",
    "homepage": "https://reacttextgame.dev/",
    "private": false,
    "sideEffects": [
        "./dist/passages/story/index.js",
        "./dist/passages/story/start.js"
    ],
    "type": "module",
    "scripts": {
        "dev": "tsc -p tsconfig.build.json --watch & tsc-alias -p tsconfig.build.json --watch",
        "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "test": "bun test --cwd ../.. packages/core/src/tests",
        "test:coverage": "bun test --cwd ../.. --coverage --coverage-dir packages/core/coverage packages/core/src/tests && bun ../../scripts/check-coverage.ts packages/core",
        "check-types": "tsc --noEmit",
        "lint": "biome check --error-on-warnings .",
        "prepack": "bun run build",
        "test-pack": "bun pm pack --dry-run && bunx --bun publint"
    },
    "author": "laruss",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "license": "MIT",
    "files": [
        "dist"
    ],
    "dependencies": {
        "crypto-js": "^4.2.0",
        "dexie": "^4.4.4",
        "dexie-react-hooks": "^4.4.0",
        "i18next": "^25.6.0",
        "jsonpath-plus": "^10.3.0",
        "react-i18next": "^16.1.0",
        "valtio": "^2.3.2"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "typescript": "^5"
    },
    "devDependencies": {
        "@types/bun": "1.3.9",
        "@types/crypto-js": "^4.2.2",
        "@types/node": "^24.6.2",
        "@types/react": "^19.0.9",
        "@types/react-dom": "^19.0.3",
        "tsc-alias": "^1.8.16"
    },
    "imports": {
        "#*": "./dist/*"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./saves": {
            "types": "./dist/saves/index.d.ts",
            "import": "./dist/saves/index.js"
        },
        "./passages": {
            "types": "./dist/passages/types/index.d.ts"
        },
        "./i18n": {
            "types": "./dist/i18n/index.d.ts",
            "import": "./dist/i18n/index.js"
        },
        "./audio": {
            "types": "./dist/audio/index.d.ts",
            "import": "./dist/audio/index.js"
        }
    }
}
