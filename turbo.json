{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "env": ["DOCS_BUILD"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
        },
        "@react-text-game/docs#build": {
            "dependsOn": ["^build"],
            "env": ["DOCS_BUILD"],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*",
                "$TURBO_ROOT$/package.json",
                "$TURBO_ROOT$/packages/core/package.json",
                "$TURBO_ROOT$/packages/core/src/**",
                "$TURBO_ROOT$/packages/core/tsconfig.json",
                "$TURBO_ROOT$/packages/mdx/package.json",
                "$TURBO_ROOT$/packages/mdx/src/**",
                "$TURBO_ROOT$/packages/mdx/tsconfig.json",
                "$TURBO_ROOT$/packages/ui/package.json",
                "$TURBO_ROOT$/packages/ui/src/**",
                "$TURBO_ROOT$/packages/ui/tsconfig.json"
            ],
            "outputs": ["build/**"]
        },
        "lint": {
            "dependsOn": ["//#lint:root"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
        },
        "//#lint:root": {
            "inputs": [
                "biome.json",
                "context7.json",
                "package.json",
                "skills-lock.json",
                "turbo.json",
                "happydom.ts",
                "scripts/**"
            ]
        },
        "check-types": {
            "dependsOn": ["^build", "^check-types"]
        },
        "test": {
            "dependsOn": ["^build"],
            "inputs": [
                "$TURBO_DEFAULT$",
                "$TURBO_ROOT$/bunfig.toml",
                "$TURBO_ROOT$/happydom.ts",
                "$TURBO_ROOT$/packages/ui/src/tests/dexie.mock.ts"
            ]
        },
        "test:coverage": {
            "dependsOn": ["^build"],
            "inputs": [
                "$TURBO_DEFAULT$",
                "$TURBO_ROOT$/bunfig.toml",
                "$TURBO_ROOT$/happydom.ts",
                "$TURBO_ROOT$/packages/ui/src/tests/dexie.mock.ts",
                "$TURBO_ROOT$/scripts/check-coverage.ts"
            ],
            "outputs": ["coverage/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "docs": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "docs:build": {
            "dependsOn": ["build"],
            "outputs": ["apps/docs/build/**"]
        }
    }
}
